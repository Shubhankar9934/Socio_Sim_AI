# Socio Sim AI - Environment Variables
# Copy to .env and fill in values

# OpenAI (required for LLM reasoning and judge)
OPENAI_API_KEY=sk-your-api-key-here

# Model selection
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o

# Simulation
POPULATION_SIZE=500
MAX_CONCURRENT_LLM_CALLS=20
SIMULATION_DAYS_DEFAULT=30

# Archetype compression (for 500+ agents)
ARCHETYPE_COUNT=80
USE_ARCHETYPES_ABOVE_AGENTS=500

# Validation
POPULATION_REALISM_THRESHOLD=0.85
DRIFT_THRESHOLD=0.3

# ChromaDB (agent memory) - leave empty for in-memory
CHROMA_PERSIST_DIR=

# --- Bias engine ---
BIAS_GAMMA_FLOOR=0.05
BIAS_GAMMA_CEILING=0.95
BIAS_EPSILON_BASE=0.05
BIAS_EPSILON_FLOOR=0.01
BIAS_EPSILON_CEILING=0.3
CALCIFICATION_RATE=0.001

# --- Media ecosystem ---
MEDIA_PRIOR_WEIGHT=0.70
MEDIA_INFLUENCE_WEIGHT=0.15
SOCIAL_INFLUENCE_WEIGHT=0.15
ATTENTION_SHARPNESS_K=5.0
ATTENTION_SHARPNESS_P=2.0
ATTENTION_ENTROPY_FLOOR=0.05
ALIGNMENT_BETA=0.15

# --- Cascade detection ---
ACTIVATION_DECAY=0.85
ACTIVATION_THRESHOLD=0.8
CASCADE_MIN_SIZE=200
CASCADE_MIN_FRACTION=0.005
CASCADE_MIN_DENSITY=0.01
FATIGUE_FACTOR=0.3
COOLDOWN_DAYS=5
COOLDOWN_DECAY=0.1
OUTRAGE_WEIGHT=0.6
VALIDATION_WEIGHT=0.3
SOCIAL_LAMBDA=0.2

# --- Research layer ---
RESEARCH_API_PROVIDER=none
RESEARCH_CACHE_PATH=data/research_cache.json
